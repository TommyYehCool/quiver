# =============================================================
# Quiver — Production 環境變數範本(phase 6E-5)
# 複製為 .env.production,填入實際值。**不要 commit 真實 secrets**。
# =============================================================
#
# 跟 .env.example(dev)的差別:
# - ENV=mainnet
# - 所有 BASE_URL 用真實 https
# - JWT_SECRET / KEK 用 strong randomness 重產
# - 啟用 Sentry / S3 backup / KMS
# - 拿掉 ngrok(production 用真 DNS + nginx)
# =============================================================

# ---- Runtime ----
ENV=mainnet
TZ=Asia/Taipei

# ---- 服務 URL ----
API_BASE_URL=https://api.quiver.io
FRONTEND_BASE_URL=https://app.quiver.io

# ---- PostgreSQL ----
# 強密碼!`openssl rand -base64 24`
POSTGRES_USER=quiver
POSTGRES_PASSWORD=__GENERATE_STRONG_PASSWORD__
POSTGRES_DB=quiver
DATABASE_URL=postgresql+asyncpg://quiver:__SAME_AS_ABOVE__@db:5432/quiver

# ---- Redis ----
# production 應該用 password / 內網隔離 / TLS
REDIS_URL=redis://:STRONG_PW@redis:6379/0

# ---- JWT ----
# `openssl rand -base64 64`
JWT_SECRET=__GENERATE_64_BYTES__
JWT_EXPIRES_SECONDS=86400

# ---- KEK ----
# 第一次 bootstrap 時從 /admin/setup 產生並複製到此(只能看到一次!)
# 同時拆 Shamir 3-of-5 備份(見 docs/runbook-bootstrap.md)
KEK_CURRENT_B64=

# ---- Google OAuth ----
# Production OAuth client(跟 dev 不同)
# Authorized redirect URI: https://api.quiver.io/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Tatum (mainnet) ----
# **付費 plan 必要**(free plan 5 個 subscription 上限)
# 從 https://dashboard.tatum.io 拿
TATUM_API_KEY_TESTNET=
TATUM_API_KEY_MAINNET=
TATUM_BASE_URL=https://api.tatum.io
WEBHOOK_CALLBACK_URL=https://api.quiver.io
# `openssl rand -hex 32` — 防止 webhook 偽造
WEBHOOK_PATH_TOKEN=__GENERATE_HEX_32__

# ---- Resend ----
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@quiver.io

# ---- BitoPro ----
BITOPRO_BASE_URL=https://api.bitopro.com/v3

# ---- 業務參數 ----
# Mainnet 提領 gas 約 14 USDT 等值的 TRX,平台收 2 USDT 自負部分 gas + 利潤
ADMIN_EMAILS=admin@quiver.io,ops@quiver.io
WITHDRAWAL_FEE_USDT=2
WITHDRAWAL_LARGE_THRESHOLD_USD=1000
MIN_WITHDRAWAL_USDT=5
RECONCILIATION_TOLERANCE_USDT=0.01

# ---- 6E-4: 冷熱錢包架構 ----
# COLD wallet:你掌控、跟系統分離的 Tron 地址(硬體錢包 / 多簽 / 紙錢包)
# 系統只讀此地址鏈上餘額,不持有私鑰。production 強烈建議用一個只給平台用的全新地址,
# 而不是混用個人錢包,避免「個人 USDT 被算進平台持有」造成 insolvency 計算失準。
COLD_WALLET_ADDRESS=
# HOT 鏈上 USDT 超過此值會在 admin 頁面跳警示,提醒移轉到 COLD
# 業界 best practice:HOT 只放營運用額度(< 20% 總資產),其餘存 COLD
HOT_MAX_USDT=5000
HOT_TARGET_USDT=2000

# ---- Sentry (phase 6E-3) ----
SENTRY_DSN=https://__public_key__@__org__.ingest.sentry.io/__project_id__
SENTRY_TRACES_SAMPLE_RATE=0.1
# 部署 CI 時自動填 git sha
SENTRY_RELEASE=

# ---- Backup (phase 6E-5) ----
# 給 infra/backup/pg_dump.sh 用
BACKUP_S3_BUCKET=quiver-prod-backups
BACKUP_S3_KMS_KEY_ID=arn:aws:kms:ap-northeast-1:__ACCOUNT__:key/__KEY_ID__
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-northeast-1

# ---- Next.js ----
NEXT_PUBLIC_API_BASE_URL=https://api.quiver.io
SERVER_API_BASE_URL=http://api:8000
