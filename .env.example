# =============================================================
# Quiver — 環境變數範本
# 複製為 .env 後填入實際值。SECRET 類請勿 commit。
# =============================================================

# ---- Runtime ----
ENV=testnet
TZ=Asia/Taipei

# ---- 服務 URL（給後端產 redirect / cookie 用） ----
API_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000

# ---- PostgreSQL ----
POSTGRES_USER=quiver
POSTGRES_PASSWORD=quiver_dev_pw
POSTGRES_DB=quiver
DATABASE_URL=postgresql+asyncpg://quiver:quiver_dev_pw@postgres:5432/quiver

# ---- Redis ----
REDIS_URL=redis://redis:6379/0

# ---- JWT ----
# 隨機產一組：openssl rand -hex 64
JWT_SECRET=
JWT_EXPIRES_SECONDS=86400

# ---- KEK（AES-GCM，用 admin UI bootstrap 後填回來） ----
# 32 bytes base64：python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
# Phase 1 用不到，Phase 3 才需要
KEK_CURRENT_B64=

# ---- Google OAuth ----
# 申請步驟見 README.md
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Tatum（Phase 3 才用） ----
TATUM_API_KEY=
TATUM_BASE_URL=https://api.tatum.io
WEBHOOK_CALLBACK_URL=
WEBHOOK_PATH_TOKEN=

# ---- Resend（Phase 2 寄通知信用） ----
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@quiver.local

# ---- BitoPro 匯率（Phase 6 用，免 key） ----
BITOPRO_BASE_URL=https://api.bitopro.com/v3

# ---- 業務參數 ----
ADMIN_EMAILS=tommy.yeh1112@gmail.com
WITHDRAWAL_FEE_USDT=1
WITHDRAWAL_LARGE_THRESHOLD_USD=1000
MIN_WITHDRAWAL_USDT=5
RECONCILIATION_TOLERANCE_USDT=0.01

# ---- ngrok（webhook 戳本機用） ----
NGROK_AUTHTOKEN=

# ---- Next.js ----
# 瀏覽器端 fetch 用（必須是 host 機可達的 URL）
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Server-side（容器內 SSR）走 docker compose 內部 DNS
SERVER_API_BASE_URL=http://api:8000
